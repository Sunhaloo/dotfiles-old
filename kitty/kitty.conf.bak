# BEGIN_KITTY_THEME 
include themes/solarized-dark-patched.conf
# include themes/solarized-light.conf
# include themes/Homebrew.conf
# END_KITTY_THEME

# General

# copy on select ( same as Windows Terminal )
copy_on_select yes

# Appearance
ea
# opacity
background_opacity 0.9
# background blur
background_blur 0

# Font Customisation
# font family
# font_family      family="JetBrainsMono Nerd Font"
# font_family      family="ZedMono Nerd Font Mono"
# font_family      family="PlemolJP Console NF"
# font_family      family="Monaspace Radon"
# font_family      family="Monaco Nerd Font Mono"
# font_family      family="Hack Nerd Font Mono"
# bold_font        auto
# italic_font      auto
# bold_italic_font auto
font_size 15.0
# ligatures ( let's test out ligatures )
disable_ligatures true
# undercurl style
undercurl_style thin-dense
# URL Customisation

# detect URLs under mouse cursor
detect_urls yes

# URL font colour
# url_color #0087bd
# URL style
url_style curly

# Hyperlinks Customisation

# Same as URL style settings
underline_hyperlinks hover

# Caret Customisation

# caret shape ( focused )
shell_integration no-cursor
# cursor shape
cursor_shape block
# caret shape ( unfocused )
cursor_shape_unfocused hollow
# caret blinking ( disable = 0 | system default = -1 )
cursor_blink_interval 0
# caret colour
# cursor #98c379

# Mouse Customisation

# mouse cursor hide ( immediately hide = -1 | disable = -1 )
mouse_hide_wait -1

# For Other Configurations
allow_remote_control yes
listen_on unix:/tmp/kitty
